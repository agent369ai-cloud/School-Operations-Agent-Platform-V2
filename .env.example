# --- LLM ---
# Provider key. Required for the parser; if missing, parser falls back to a deterministic mock
# so the demo still works (but the rubric expects real LLM calls — set this).
OPENAI_API_KEY=

# Base URL for OpenAI-compatible inference endpoint (defaults to https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name. gpt-4o-mini works well for structured outputs.
LLM_MODEL=gpt-4o-mini

# --- Database ---
# SQLite default for local dev. For Render/Postgres use:
#   postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./school.db

# --- Auth ---
# CRITICAL: replace with a long random string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`)
SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=8

# --- Telegram (optional but recommended) ---
# Get from @BotFather on Telegram, then set webhook:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://<your-app>/api/v1/webhooks/telegram&secret_token=<SECRET>"
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Scheduler policy ---
# Quiet-hours window (24h). Reminders inside [start, end) are suppressed.
QUIET_HOURS_START=20
QUIET_HOURS_END=8

# --- App ---
APP_ENV=development
